-- Fling Script by Jack
-- Method: Spin-weld fling (most reliable, physics-based)
-- UI: Rayfield (Clean & Modern Player Selector)

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local lp = Players.LocalPlayer

-- ══════════════════════════════════════════
--  CONFIG & STATE
-- ══════════════════════════════════════════
local cfg = {
    spinSpeed    = 9999,   
    flingTime    = 0.3,    
    continuous   = false,  
    autoFarm     = false,  
}

local targetName   = nil
local flinging     = false
local flingConn    = nil
local origCFrame   = nil

-- ══════════════════════════════════════════
--  HELPERS
-- ══════════════════════════════════════════
local function getChar(plr)
    return plr and plr.Character
end

local function getHRP(char)
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getHum(char)
    return char and char:FindFirstChildOfClass("Humanoid")
end

local function getNearestPlayer()
    local myHRP = getHRP(getChar(lp))
    if not myHRP then return nil end
    local closest, dist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= lp then
            local hrp = getHRP(getChar(p))
            if hrp then
                local d = (hrp.Position - myHRP.Position).Magnitude
                if d < dist then
                    dist = d
                    closest = p
                end
            end
        end
    end
    return closest
end

-- ══════════════════════════════════════════
--  CORE FLING
-- ══════════════════════════════════════════
local function stopFling()
    flinging = false
    if flingConn then flingConn:Disconnect(); flingConn = nil end

    local myChar = getChar(lp)
    local myHum  = getHum(myChar)
    local myHRP  = getHRP(myChar)
    
    if myHRP then
        local bav = myHRP:FindFirstChild("FlingBAV")
        if bav then bav:Destroy() end
        myHRP.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        myHRP.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    end
    
    if myHum then
        myHum.PlatformStand = false
        myHum.AutoRotate    = true
    end
    
    if myHRP and origCFrame then
        myHRP.CFrame = origCFrame
        origCFrame   = nil
    end
end

local function flingPlayer(targetPlr)
    if flinging then stopFling() end
    if not targetPlr or targetPlr == lp then return end

    local myChar  = getChar(lp)
    local myHRP   = getHRP(myChar)
    local myHum   = getHum(myChar)
    local tgtChar = getChar(targetPlr)
    local tgtHRP  = getHRP(tgtChar)

    if not (myHRP and myHum and tgtHRP) then return end

    origCFrame = myHRP.CFrame
    flinging   = true

    myHum.PlatformStand = true
    myHum.AutoRotate    = false

    -- Use massive BodyAngularVelocity to spin us
    local bav = Instance.new("BodyAngularVelocity")
    bav.Name = "FlingBAV"
    bav.AngularVelocity = Vector3.new(999999, 999999, 999999)
    bav.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bav.P = math.huge
    bav.Parent = myHRP

    -- Noclip our character so we can glitch inside them
    for _, part in ipairs(myChar:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = false
        end
    end

    local elapsed = 0

    flingConn = RunService.Heartbeat:Connect(function(dt)
        elapsed = elapsed + dt

        if not (myHRP and myHRP.Parent and tgtHRP and tgtHRP.Parent) then
            stopFling()
            return
        end

        -- Re-apply insane velocities every frame
        myHRP.AssemblyAngularVelocity = Vector3.new(999999, 999999, 999999)
        myHRP.AssemblyLinearVelocity = Vector3.new(0, 0, 0)

        -- Teleport exactly on top of them, predicting their movement slightly
        local pred = tgtHRP.AssemblyLinearVelocity * dt * 1.2
        myHRP.CFrame = tgtHRP.CFrame + pred

        if elapsed >= cfg.flingTime then
            stopFling()

            if cfg.continuous then
                task.wait(1)
                flingPlayer(targetPlr)
            end
        end
    end)
end

-- ══════════════════════════════════════════
--  RAYFIELD UI
-- ══════════════════════════════════════════
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "💀 Fling Hub",
   LoadingTitle = "Fling Script by Jack",
   LoadingSubtitle = "Physics-based Spin Fling",
   ConfigurationSaving = { Enabled = false },
   KeySystem = false
})

local MainTab = Window:CreateTab("Main", 4483362458)

local PlayerDropdown = MainTab:CreateDropdown({
   Name = "Select Target",
   Options = {""},
   CurrentOption = "",
   MultipleOptions = false,
   Flag = "PlayerDropdown",
   Callback = function(Option)
       targetName = Option[1]
   end,
})

local function updatePlayers()
    local list = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= lp then
            table.insert(list, p.Name)
        end
    end
    if #list == 0 then table.insert(list, "No Players") end
    PlayerDropdown:Refresh(list, true)
end

updatePlayers()
Players.PlayerAdded:Connect(updatePlayers)
Players.PlayerRemoving:Connect(updatePlayers)

MainTab:CreateToggle({
   Name = "Auto-Nearest Player",
   CurrentValue = cfg.autoFarm,
   Flag = "AutoNearest",
   Callback = function(Value)
       cfg.autoFarm = Value
   end,
})

MainTab:CreateToggle({
   Name = "Continuous Fling",
   CurrentValue = cfg.continuous,
   Flag = "ContinuousFling",
   Callback = function(Value)
       cfg.continuous = Value
   end,
})

MainTab:CreateButton({
   Name = "⚡ FLING TARGET",
   Callback = function()
       local t = nil
       if cfg.autoFarm then
           t = getNearestPlayer()
       elseif targetName and targetName ~= "No Players" and targetName ~= "" then
           t = Players:FindFirstChild(targetName)
       end
       
       if t then
           Rayfield:Notify({
               Title = "Flinging",
               Content = "Flinging " .. t.Name,
               Duration = 2,
               Image = 4483362458,
           })
           flingPlayer(t)
       else
           Rayfield:Notify({
               Title = "Error",
               Content = "No valid target selected or found!",
               Duration = 2,
               Image = 4483362458,
           })
       end
   end,
})

MainTab:CreateButton({
   Name = "🔃 FLING ALL (Chaos)",
   Callback = function()
       Rayfield:Notify({
           Title = "Fling All",
           Content = "Flinging everyone in the server...",
           Duration = 3,
           Image = 4483362458,
       })
       for _, p in ipairs(Players:GetPlayers()) do
           if p ~= lp then
               flingPlayer(p)
               task.wait(0.6)
           end
       end
   end,
})

MainTab:CreateButton({
   Name = "⛔ STOP",
   Callback = function()
       stopFling()
       Rayfield:Notify({
           Title = "Stopped",
           Content = "Fling cancelled.",
           Duration = 2,
           Image = 4483362458,
       })
   end,
})
